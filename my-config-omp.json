{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "transient_prompt": {
    "template": "\ue285 ",
    "foreground": "#FEF5ED",
    "background": "transparent"
  },
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "macos": "\uf179 ",
            "ubuntu": "\uf31b ",
            "windows": "\ue62a "
          },
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "<transparent,#FEF5ED>\ue0b2</>",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}",
          "foreground": "#011627",
          "background": "#FEF5ED",
          "type": "os",
          "style": "diamond"
        },
        {
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "<transparent,#FEF5ED>\ue0b2</>",
          "template": "\uf489 {{ .Name }}",
          "foreground": "#011627",
          "background": "#FEF5ED",
          "type": "shell",
          "style": "diamond"
        },
        {
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "<transparent,#A58EE0>\ue0b2</>",
          "template": "\ue266 MEM: {{ round .PhysicalPercentUsed .Precision }}% | {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB",
          "foreground": "#ffffff",
          "background": "#A58EE0",
          "type": "sysinfo",
          "style": "diamond"
        },
        {
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "<transparent,#6FA07F>\ue0b2</>",
          "template": "{{ .Icon }}{{ if ne .Status \"stopped\" }}{{ .Artist }} - {{ .Track }}{{ end }}",
          "foreground": "#ffffff",
          "background": "#6FA07F  ",
          "type": "spotify",
          "style": "diamond",
          "options": { "playing_icon": " \ue602 ", "paused_icon": "\uf04c ", "stopped_icon": "\uf04d " }
        },
        {
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "<transparent,#E8B192>\ue0b2</>",
          "template": "{{ if eq .Type \"wifi\"}}\uf1eb{{ else if eq .Type \"ethernet\"}}ETHERNET: \udb80\ude00 {{ end }}",
          "foreground": "#ffffff",
          "background": "#E8B192  ",
          "type": "connection",
          "style": "diamond"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "branch_icon": "\ue725 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "leading_diamond": "\ue0b2",
          "trailing_diamond": "\ue0b0",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "foreground": "#011627",
          "background": "#17D7A0",
          "type": "git",
          "style": "diamond"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\u256d\u2500",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "time_format": "15:04"
          },
          "template": " 👾 {{ .CurrentDate | date .Format }} |",
          "type": "time",
          "style": "plain"
        },
        {
          "template": " \uf292 ",
          "type": "root",
          "style": "plain"
        },
        {
          "properties": {
            "folder_icon": "\ueaf7 ",
            "folder_separator_icon": " \uf061 ",
            "home_icon": "\ueb06 "
          },
          "template": " {{ .Path }} ",
          "type": "path",
          "style": "plain"
        }
      ],
      "newline": true
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true
          },
          "template": "\u2570\u2500 ",
          "type": "status",
          "style": "plain"
        }
      ],
      "newline": true
    }
  ],
  "version": 3
}
